# C&C Inc - Performance: Cache static assets for 1 year
# Supported by Netlify and Cloudflare Pages. GitHub Pages does not support custom headers.

/assets/imgs/*
  Cache-Control: public, max-age=31536000, immutable

/assets/stylesheets/*
  Cache-Control: public, max-age=31536000, immutable

/assets/js/*
  Cache-Control: public, max-age=31536000, immutable

/assets/videos/*
  Cache-Control: public, max-age=31536000, immutable

/assets/icons/*
  Cache-Control: public, max-age=31536000, immutable

/assets/images/*
  Cache-Control: public, max-age=31536000, immutable
